<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvProfileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Professional Profile"
        android:textColor="#102A43"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvProfileTitle"
        app:layout_constraintBottom_toTopOf="@id/btnSaveProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Years of Experience" android:textColor="#486581" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etProfileExp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/pill_bg"
                android:textColor="@color/black"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="20dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Consultation Fee ($)" android:textColor="#486581" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etProfileFee"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/pill_bg"
                android:textColor="@color/black"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="20dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="About / Bio" android:textColor="#486581" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etProfileAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="150dp"
                android:background="@drawable/pill_bg"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="@color/black"
                android:padding="20dp"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ... rest of XML above remains the same ... -->

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveProfile"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="#102A43"
        android:text="Save Changes"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnLogout" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="#D32F2F"
        android:text="Log Out"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>