<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBackToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="← Back to Login"
        android:textAllCaps="false"
        android:textColor="#3D5AFE"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/signUpHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackToLogin">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="#102A43"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the Medical Network"
            android:textColor="#486581"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ScrollView ensures fields are accessible on smaller screens or when keyboard pops up -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signUpHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Name -->
            <EditText
                android:id="@+id/etDocName"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/pill_bg"
                android:hint="Full Name (Dr. ...)"
                android:textColorHint="#666666"
                android:inputType="textPersonName"
                android:paddingHorizontal="24dp"
                android:textColor="@color/black" />


            <!-- Specialization (e.g. Cardiologist) -->
            <EditText
                android:id="@+id/etDocSpecialty"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/pill_bg"
                android:hint="Specialization"
                android:textColorHint="#666666"
                android:inputType="text"
                android:paddingHorizontal="24dp"
                android:textColor="@color/black" />

            <!-- Email -->
            <EditText
                android:id="@+id/etDocEmail"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/pill_bg"
                android:hint="Professional Email"
                android:textColorHint="#666666"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="24dp"
                android:textColor="@color/black" />

            <!-- Password -->
            <EditText
                android:id="@+id/etDocPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/pill_bg"
                android:hint="Create Password"
                android:textColorHint="#666666"
                android:inputType="textPassword"
                android:paddingHorizontal="24dp"
                android:textColor="@color/black" />

            <!-- Register Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDoSignUp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/circle_black"
                android:backgroundTint="#102A43"
                android:text="Register as Doctor"
                android:textColor="@color/white"
                android:textStyle="bold" />


        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>