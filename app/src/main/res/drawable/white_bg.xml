<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- The solid white fill -->
    <solid android:color="#F2F5FF" />

    <!-- High radius for that modern, bubbly look -->
    <corners android:radius="44dp" />

    <!-- Optional: Add a very light stroke if it bleeds into the background -->
    <stroke
        android:width="1dp"
        android:color="#0D000000" />
</shape>